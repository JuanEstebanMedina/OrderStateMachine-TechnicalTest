# Local defaults for running the backend directly.
PERSISTENCE_BACKEND=memory
CORS_ALLOWED_ORIGINS=http://localhost:5173

# DynamoDB Local values. Use only fake local credentials for DynamoDB Local.
DYNAMODB_TABLE_NAME=OrderStateMachineLocal
DYNAMODB_ENDPOINT_URL=http://localhost:8001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Optional deployment/runtime value. Leave empty for local Uvicorn.
# API_GATEWAY_BASE_PATH=/prod
